APP_NAME=Foreign Exchange Deal Manager
APP_VERSION=0.1.0
DEBUG=false
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# PostgreSQL (local dev — порт 5433 чтобы не конфликтовать с IdP)
DATABASE_URL=postgresql+asyncpg://fx:fx_password@localhost:5433/fx_deal_manager

# JWT validation (identity-provider, read-only consumer)
JWT_ISSUER=http://localhost:8083
JWKS_URL=http://localhost:8083/.well-known/jwks.json

# CORS — UI на :5173 или :3000 (allowlist IdP)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
AUTO_MIGRATE=true

# Position system stub (empty = in-process stub)
# POSITION_SYSTEM_URL=http://localhost:9000/api/v1/positions
POSITION_SEND_RETRIES=3
POSITION_SEND_BACKOFF_SECONDS=0.5
